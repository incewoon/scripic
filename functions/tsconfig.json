{
  "compilerOptions": {
    "target": "es2022",
    "module": "Node16",                    // ← "commonjs" → "Node16" (필수)
    "moduleResolution": "node16",
    "outDir": "lib",
    "rootDir": "./src",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "5.0"           // 주인님께서 변경하신 값 유지
  },
  "include": [
    "src/**/*.ts"
  ]
}
